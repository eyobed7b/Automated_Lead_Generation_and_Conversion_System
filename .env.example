# ============================================================
# Tenacious Conversion Engine — Environment Variables
# Copy to .env and fill in values before running.
# ============================================================

# KILL SWITCH — set to true only when ready for live outbound
# Default MUST be false (routes all outbound to staff sink)
LIVE_OUTBOUND=false
STAFF_SINK_EMAIL=sandbox@tenacious-staff.internal
STAFF_SINK_PHONE=+12025550100

# Email — Resend (free tier, 3000 emails/month, no credit card)
# Sign up at resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=outreach@yourdomain.com
RESEND_REPLY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# SMS — Africa's Talking sandbox (free, no credit card)
# Sign up at account.africastalking.com
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=atsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
AFRICASTALKING_SENDER_ID=TENACIOUS

# CRM — HubSpot Developer Sandbox (free)
# Create at app.hubspot.com/developer-sandbox
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HUBSPOT_PORTAL_ID=12345678

# Calendar — Cal.com (self-hosted Docker)
# docker-compose up calcom
CALCOM_API_KEY=cal_live_xxxxxxxxxxxxxxxxxxxx
CALCOM_BASE_URL=http://localhost:3000
CALCOM_EVENT_TYPE_ID=1

# LLM — OpenRouter (all agent calls route through here)
# Sign up at openrouter.ai — no credit card required for free tier
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Dev tier model (Days 1-4, target under $4 total)
# Options: deepseek/deepseek-chat-v3-0324 | qwen/qwen3-235b-a22b
DEV_MODEL=deepseek/deepseek-chat-v3-0324

# Eval tier model (Days 5-7 sealed scoring, target under $12 total)
# Options: anthropic/claude-sonnet-4-6 | openai/gpt-4o
EVAL_MODEL=anthropic/claude-sonnet-4-6

# Observability — Langfuse cloud free tier
# Sign up at langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# Agent behavior
MAX_OUTBOUND_PER_DAY=60
MIN_ICP_CONFIDENCE=0.50
SIGNAL_GROUNDED_THRESHOLD=0.75
JOB_POST_VELOCITY_MIN_ROLES=5
